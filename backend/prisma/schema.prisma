generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Firm {
  id               String       @id @default(uuid())
  name             String
  qboRealmId       String?      @unique @map("qbo_realm_id")
  xeroTenantId     String?      @unique @map("xero_tenant_id")
  accessToken      String?      @map("access_token")
  refreshToken     String?      @map("refresh_token")
  tokenExpiresAt   DateTime?    @map("token_expires_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  isSubscribed     Boolean      @default(false) @map("is_subscribed")
  plan             String       @default("TRIAL")
  stripeCustomerId String?      @unique @map("stripe_customer_id")
  subscriptionId   String?      @unique @map("subscription_id")
  trialEndsAt      DateTime?    @map("trial_ends_at")
  paymentJobs      PaymentJob[]
  splitRules       SplitRule[]

  @@map("firms")
}

model SplitRule {
  id               String       @id @default(uuid())
  firmId           String       @map("firm_id")
  parentCustomerId String       @map("parent_customer_id")
  ruleType         String       @map("rule_type")
  ruleConfig       Json         @map("rule_config")
  isActive         Boolean      @default(true) @map("is_active")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  paymentJobs      PaymentJob[]
  firm             Firm         @relation(fields: [firmId], references: [id], onDelete: Cascade)

  @@map("split_rules")
}

model PaymentJob {
  id           String       @id @default(uuid())
  firmId       String       @map("firm_id")
  ruleId       String?      @map("rule_id")
  paymentId    String       @map("payment_id")
  status       JobStatus    @default(QUEUED)
  totalAmount  Decimal      @map("total_amount") @db.Decimal(15, 2)
  splitResult  Json?        @map("split_result")
  errorMessage String?      @map("error_message")
  createdAt    DateTime     @default(now()) @map("created_at")
  completedAt  DateTime?    @map("completed_at")
  auditEntries AuditEntry[]
  firm         Firm         @relation(fields: [firmId], references: [id], onDelete: Cascade)
  rule         SplitRule?   @relation(fields: [ruleId], references: [id])

  @@unique([firmId, paymentId])
  @@map("payment_jobs")
}

model AuditEntry {
  id            String     @id @default(uuid())
  jobId         String     @map("job_id")
  subLocationId String     @map("sub_location_id")
  invoiceId     String     @map("invoice_id")
  amountApplied Decimal    @map("amount_applied") @db.Decimal(15, 2)
  qboPaymentId  String?    @map("qbo_payment_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  job           PaymentJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("audit_entries")
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETE
  FAILED
  ROLLED_BACK
}
