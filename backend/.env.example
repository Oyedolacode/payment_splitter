# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/payment_splitter"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── JWT (generate with: openssl rand -base64 64) ────────────────────────────
JWT_SECRET="replace-with-a-long-random-secret"

# ─── Encryption (generate with: openssl rand -hex 32) ────────────────────────
# Used to AES-256 encrypt OAuth tokens at rest
ENCRYPTION_KEY="replace-with-64-char-hex-string"

# ─── QuickBooks Online OAuth 2.0 ─────────────────────────────────────────────
# Get these from: https://developer.intuit.com → My Apps → Keys & OAuth
QBO_CLIENT_ID="your-qbo-client-id"
QBO_CLIENT_SECRET="your-qbo-client-secret"
QBO_REDIRECT_URI="http://localhost:3001/auth/qbo/callback"
QBO_ENVIRONMENT="sandbox"   # "sandbox" | "production"

# ─── Frontend URL (for CORS + redirects) ─────────────────────────────────────
FRONTEND_URL="http://localhost:3000"

# ─── Stripe (add when monetization is wired up in Phase 5) ───────────────────
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
